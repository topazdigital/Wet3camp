# ============================================================
# Wet3 Camp — API Server Environment Variables
# Copy this to your server's /home/admin/api-server/env file
# and fill in real values.
# ============================================================

# MySQL Database (required — app will not start without these)
DB_HOST=localhost
DB_PORT=3306
DB_USER=admin_betcheza
DB_PASS=YOUR_MYSQL_PASSWORD_HERE
DB_NAME=admin_wet3camp

# JWT signing secret (required — use a long random string)
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_STRING

# Port (required)
PORT=3000

# SMTP for OTP emails (optional — OTPs shown in server logs if not set)
# SMTP_HOST=mail.wet3.camp
# SMTP_PORT=587
# SMTP_USER=noreply@wet3.camp
# SMTP_PASS=your_smtp_password
# SMTP_SECURE=false

# OpenAI for AI bio generation (optional — uses Replit AI Integrations in dev)
# AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
