Options -Indexes -MultiViews
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Proxy all /api/* requests to the Node.js server on port 8080
  # Uses %{REQUEST_URI} so the full path + query string is preserved
  RewriteCond %{REQUEST_URI} ^/api [NC]
  RewriteRule ^ http://localhost:8080%{REQUEST_URI} [P,L,QSA]

  # SPA fallback — serve index.html for all non-file, non-directory routes
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  RewriteRule . /index.html [L]
</IfModule>

# ── Static asset caching ─────────────────────────────────────────────────────
<FilesMatch "\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|webp)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

<FilesMatch "index\.html$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>
