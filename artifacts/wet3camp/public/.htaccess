Options -Indexes -MultiViews
DirectoryIndex index.html

# ── API proxy via RewriteRule [P] ────────────────────────────────────────────
# ProxyPass is NOT allowed in .htaccess context — use RewriteRule with [P] flag
# instead (which goes through mod_rewrite but proxies via mod_proxy internally).
# This works with standard DirectAdmin AllowOverride All settings.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Proxy /api/* and /api to the Node.js server on port 8080
  RewriteRule ^api(/.*)?$ http://localhost:8080/api$1 [P,L,NE]

  # SPA fallback — serve index.html for all non-file, non-api routes
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# ── Static asset caching ─────────────────────────────────────────────────────
<FilesMatch "\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|webp)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

<FilesMatch "index\.html$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>
