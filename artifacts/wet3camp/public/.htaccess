Options -Indexes -MultiViews
DirectoryIndex index.html

# ── API proxy ─────────────────────────────────────────────────────────────────
# Method A: ProxyPass (Apache 2.4+ with mod_proxy enabled in VirtualHost)
<IfModule mod_proxy.c>
  ProxyPreserveHost On
  ProxyPass        /api http://localhost:8080/api
  ProxyPassReverse /api http://localhost:8080/api
</IfModule>

# Method B: RewriteRule [P] fallback (same result via mod_rewrite + mod_proxy)
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Skip /api paths if already handled by ProxyPass above
  RewriteCond %{REQUEST_URI} ^/api [NC]
  RewriteRule ^ http://localhost:8080%{REQUEST_URI} [P,L,QSA,NE]

  # SPA fallback — serve index.html for all non-file, non-directory routes
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  RewriteRule . /index.html [L]
</IfModule>

# ── Static asset caching ─────────────────────────────────────────────────────
<FilesMatch "\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|webp)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

<FilesMatch "index\.html$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>
