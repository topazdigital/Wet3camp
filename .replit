modules = ["nodejs-20", "web", "bash", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev & sleep 3 && PORT=5000 pnpm --filter @workspace/wet3camp run dev"
waitForPort = 5000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
NODE_ENV = "development"
BASE_PATH = "/"
APP_URL = "https://c5a150d4-ef03-474e-a2d3-f46135a51966-00-3kco7btl0yjd8.picard.replit.dev"
SITE_URL = "https://c5a150d4-ef03-474e-a2d3-f46135a51966-00-3kco7btl0yjd8.picard.replit.dev"
PORT = "8080"

[nix]
channel = "stable-25_05"
